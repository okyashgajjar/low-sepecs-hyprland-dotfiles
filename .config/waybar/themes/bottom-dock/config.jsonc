{
    "include": [
        "/home/riceyg/.config/waybar/modules.jsonc"
    ],
    "layer": "top",
    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 44,
    "margin-bottom": 8,
    "margin-left": 200,
    "margin-right": 200,
    
    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces"
    ],
    
    "modules-center": [
        "clock"
    ],
    
    "modules-right": [
        "tray",
        "pulseaudio",
        "network",
        "battery",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "󰣇",
        "on-click": "rofi -show drun -theme ~/.config/rofi/themes/modern/launcher.rasi",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": {
            "*": 5
        }
    },

    "clock": {
        "format": "{:%H:%M · %a %d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    }
}
