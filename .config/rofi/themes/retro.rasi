@import "../colors.rasi"
* {
    background-color: transparent;
    text-color: @fg;
}
window {
    width: 600px;
    background-color: @bg;
    border: 4px solid;
    border-color: @accent;
    border-radius: 0;
}
element {
    padding: 10px;
    border-radius: 0;
}
element selected {
    background-color: @accent;
    text-color: @bg;
}
